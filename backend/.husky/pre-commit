#!/bin/sh

repo_root="$(git rev-parse --show-toplevel)" || exit 1

# Skip backend checks for commits that only touch the frontend for now.
if ! git -C "$repo_root" diff --cached --name-only -- backend/ | grep -q .; then
  echo "No backend files staged, skipping backend pre-commit checks."
  exit 0
fi

cd "$repo_root/backend" || exit 1

echo "Running format..."
yarn format || exit 1

echo "Running lint..."
yarn lint || exit 1

git add src test || exit 1

echo "Running typecheck..."
yarn typecheck || exit 1
