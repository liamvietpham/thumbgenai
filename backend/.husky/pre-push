#!/bin/sh

repo_root="$(git rev-parse --show-toplevel)" || exit 1

# Skip backend tests when the push only contains frontend changes.
has_backend_changes=false

while read -r local_ref local_sha remote_ref remote_sha; do
  # Ignore deleted refs.
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    changed_files="$(git -C "$repo_root" diff-tree --no-commit-id --name-only -r "$local_sha" -- backend/)"
  else
    changed_files="$(git -C "$repo_root" diff --name-only "$remote_sha..$local_sha" -- backend/)"
  fi

  if [ -n "$changed_files" ]; then
    has_backend_changes=true
    break
  fi
done

if [ "$has_backend_changes" = false ]; then
  echo "No backend files in pushed commits, skipping backend pre-push checks."
  exit 0
fi

cd "$repo_root/backend" || exit 1

echo "Running unit tests..."
yarn test --runInBand || exit 1

echo "Running e2e tests..."
yarn test:e2e --runInBand || exit 1
